# ==========================================================================
# Template das variaveis de ambiente (Lote 9).
#
# Como usar:
#   1. Copie este arquivo para .env          (cp .env.example .env)
#   2. Preencha com valores REAIS no .env
#
# O .env NUNCA vai para o Git (esta no .gitignore). Este .env.example VAI para
# o Git, por isso contem APENAS placeholders: sem senha, login, nome real de
# banco, token, secret ou connection string verdadeira.
#
# Carga das variaveis:
#   - docker compose le este .env automaticamente;
#   - para rodar a app no host: ./run-local.ps1 (Windows) ou,
#     no bash:  set -a; source .env; set +a
# ==========================================================================

# --------------------------------------------------------------------------
# SQL Server (pix-payment-api) — Lotes 2..5
# --------------------------------------------------------------------------
SQLSERVER_HOST=localhost
SQLSERVER_PORT=1433
SQLSERVER_DATABASE=your_database_name
SQLSERVER_USERNAME=your_username
SQLSERVER_PASSWORD=your_password

# --------------------------------------------------------------------------
# Redis (pix-payment-api) — Lote 3 (idempotencia)
# --------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379

# --------------------------------------------------------------------------
# Kafka — Lote 6 (Transactional Outbox) / Lote 7 (consumer)
# Valores locais nao sensiveis: Kafka local roda em PLAINTEXT, sem credenciais.
# --------------------------------------------------------------------------
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PIX_PAYMENT_EVENTS_TOPIC=pix.payment.events
KAFKA_CONSUMER_GROUP_ID=pix-notification-worker

# --------------------------------------------------------------------------
# MongoDB (pix-notification-worker) — Lote 7 (auditoria)
# As credenciais do Mongo sao SENSIVEIS: preencha apenas no .env (fora do Git).
# A MONGO_URI deve usar os mesmos usuario/senha (authSource=admin).
# --------------------------------------------------------------------------
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DATABASE=your_database_name
MONGO_ROOT_USERNAME=your_username
MONGO_ROOT_PASSWORD=your_password
MONGO_URI=mongodb://your_username:your_password@localhost:27017/your_database_name?authSource=admin

# --------------------------------------------------------------------------
# Portas das aplicacoes (Lote 9)
# --------------------------------------------------------------------------
PAYMENT_API_PORT=8080
NOTIFICATION_WORKER_PORT=8081

# --------------------------------------------------------------------------
# Frontend demo (Lote 10)
# FRONTEND_PORT: porta do host para abrir a vitrine (http://localhost:FRONTEND_PORT).
# API_BASE_URL: deixe VAZIO para usar o proxy do nginx (mesma origem, sem CORS).
#   Preencha apenas para apontar o frontend a uma API externa (que precisaria
#   liberar CORS). Nao e sensivel; nunca coloque segredos aqui.
# --------------------------------------------------------------------------
FRONTEND_PORT=8088
API_BASE_URL=

# --------------------------------------------------------------------------
# Publisher assincrono da Outbox (Lote 6)
# --------------------------------------------------------------------------
OUTBOX_PUBLISHER_ENABLED=true
OUTBOX_PUBLISHER_FIXED_DELAY_MS=5000
OUTBOX_PUBLISHER_BATCH_SIZE=20
OUTBOX_PUBLISHER_MAX_ATTEMPTS=5
